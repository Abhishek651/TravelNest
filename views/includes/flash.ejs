<!-- Flash messages for user feedback -->

<!-- Success messages -->
<% if (success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3 mt-3" role="alert">
        <h4><%= success %></h4>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<!-- Error messages -->
<% if (error && error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3 mt-3" role="alert">
        <h4><%= error %></h4>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>

<!-- Failure messages -->
<% if (failure && failure.length) { %>
    <div class="alert alert-warning alert-dismissible fade show col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3 mt-3" role="alert">
        <h4><%= failure %></h4>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
<% } %>