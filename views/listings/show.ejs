<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/starbility.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <title><%= singleListing.title%> - TravelNest</title>
</head>
<body>
    <%- include('../includes/navbar.ejs') %>

    <div class="container my-5">
        <%- include('../includes/flash.ejs') %>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="show-card">
                    <img src="<%= singleListing.image.url%>" class="show-image" alt="<%= singleListing.title%>">
                    <div class="card-body p-4">
                        <h2 class="card-title fw-bold mb-3"><%= singleListing.title%></h2>
                        <p class="text-muted mb-4"><i class="fa-solid fa-location-dot"></i> <%= singleListing.location%>, <%= singleListing.country%></p>
                        
                        <p class="card-text mb-4"><%= singleListing.description%></p>
                        
                        <h4 class="text-primary fw-semibold mb-4">
                            <i class="fa-solid fa-indian-rupee-sign"></i> <%= singleListing.price%> <small class="text-muted fs-6">/ night</small>
                        </h4>
                        <h6 class=" fw-semibold mb-4">
                            Owned By : <%= singleListing.owner.username %>
                        </h6>
                        
                        <div class="d-flex gap-2">
                            <% if(currentUser && currentUser.equals(singleListing.owner._id)){ %>
                                <a class="btn btn-primary btn-edit" href="/listings/<%= singleListing._id%>/edit">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit
                                </a>
                                <form action="/listings/<%= singleListing._id%>?_method=DELETE" method="POST" class="d-inline">
                                    <button class="btn btn-danger">
                                        <i class="fa-solid fa-trash"></i> Delete
                                    </button>
                                </form>
                            <% } %>
                            <a class="btn btn-outline-secondary ms-auto" href="/listings">
                                <i class="fa-solid fa-arrow-left"></i> Back
                            </a>
                        </div>
                    </div>
                </div>

                <section class="review-section">
                    <% if (currentUser) { %>
                        <h4 class="fw-bold mb-3">Add a Review</h4>
                        <form action="/listings/<%= singleListing._id %>/review" method="POST" class="needs-validation" novalidate>
                            <fieldset class="starability-growRotate">
                                <legend>Rate : </legend>
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked aria-label="No rating." />
                                <input type="radio" id="rate1" name="review[rating]" value="1" />
                                <label for="rate1">1 star.</label>
                                <input type="radio" id="rate2" name="review[rating]" value="2" />
                                <label for="rate2">2 stars.</label>
                                <input type="radio" id="rate3" name="review[rating]" value="3" />
                                <label for="rate3">3 stars.</label>
                                <input type="radio" id="rate4" name="review[rating]" value="4" />
                                <label for="rate4">4 stars.</label>
                                <input type="radio" id="rate5" name="review[rating]" value="5" />
                                <label for="rate5">5 stars.</label>
                                <span class="starability-focus-ring"></span>
                            </fieldset>
                            <div class="mb-3">
                                <label for="reviewComment" class="form-label">Comment</label>
                                <textarea id="reviewComment" class="form-control" rows="3" placeholder="Write your review" name="review[comment]" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary">Submit Review</button>
                        </form>
                    <% } %>
                    

                    <h5 class="fw-semibold mt-5 mb-3">All Reviews</h5>
                    <div class="row row-cols-1 row-cols-md-2 g-3">
                        <% for(let review of singleListing.review){%>
                        <div class="col">
                            <div class="card h-100">
                                <div class="card-body d-flex flex-column">
                                    <div class="flex-grow-1">
                                        <p>By: <%= review.createdBy.username %></p>
                                        <p class="starability-result" data-rating="<%= review.rating %>">
                                            Rated: <%= review.rating %> stars
                                        </p>
                                        <h6 class="card-text"><%= review.comment %></h6>
                                    </div>
                                    <% if (currentUser && currentUser.equals(review.createdBy)) { %>
                                        <form class="align-self-end" action="/listings/<%= singleListing._id%>/review/<%=review._id%>?_method=DELETE" method="POST">
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fa-solid fa-trash"></i> Delete
                                        </button>
                                    </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <%}%>
                    </div>
                </section>
            </div>
        </div>
    </div>
    
    <%- include('../includes/footer.ejs') %>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/formValidation.js"></script>
</body>
</html>
